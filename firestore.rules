rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - each user can only read/write their own document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Bookings - customers can read/write their own, staff can read assigned bookings,
    // any authenticated user can update (for staff marking complete)
    match /bookings/{bookingId} {
      allow read: if request.auth != null &&
        (resource.data.customerId == request.auth.uid ||
         resource.data.staffId != null);
      allow create: if request.auth != null &&
        request.resource.data.customerId == request.auth.uid;
      allow update: if request.auth != null &&
        (resource.data.customerId == request.auth.uid ||
         resource.data.staffId != null);
    }

    // Services - all authenticated users can read; writes are restricted
    match /services/{serviceId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
