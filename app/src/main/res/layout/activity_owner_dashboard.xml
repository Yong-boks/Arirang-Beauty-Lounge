<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/activity_horizontal_margin"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <!-- Header Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#00796B">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Welcome, Owner!"
                    android:textColor="@color/colorWhite"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSalonCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Salon Code: —"
                    android:textColor="#B2DFDB"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/colorWhite">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvStaffCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0 Staff"
                        android:textColor="#00796B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Members"
                        android:textColor="@color/colorGrey"
                        android:textSize="11sp"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/colorWhite">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCustomerCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0 Clients"
                        android:textColor="@color/colorPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Customers"
                        android:textColor="@color/colorGrey"
                        android:textSize="11sp"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/colorWhite">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvBookingCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0 Bookings"
                        android:textColor="#FF6F00"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Total"
                        android:textColor="@color/colorGrey"
                        android:textSize="11sp"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Action Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManageStaff"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="👥 Manage Staff"
            android:textSize="15sp"
            android:textColor="@color/colorWhite"
            android:layout_marginBottom="10dp"
            app:backgroundTint="#00796B"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewAllBookings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📅 All Bookings"
            android:textSize="15sp"
            android:textColor="@color/colorWhite"
            android:layout_marginBottom="10dp"
            app:backgroundTint="#00796B"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInventory"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📦 Inventory Management"
            android:textSize="15sp"
            android:textColor="@color/colorWhite"
            android:layout_marginBottom="10dp"
            app:backgroundTint="#00796B"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReports"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📊 Reports &amp; Analytics"
            android:textSize="15sp"
            android:textColor="@color/colorWhite"
            android:layout_marginBottom="10dp"
            app:backgroundTint="#00796B"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManageSchedules"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🗓️ Manage Schedules"
            android:textSize="15sp"
            android:textColor="@color/colorWhite"
            android:layout_marginBottom="24dp"
            app:backgroundTint="#00796B"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_logout"
            android:textSize="16sp"
            android:textColor="#00796B"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#00796B"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>
